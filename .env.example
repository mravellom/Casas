# Base de datos
DATABASE_URL=postgresql+asyncpg://inmoalert:inmoalert_pass@db:5432/inmoalert

# Redis (para Celery)
REDIS_URL=redis://redis:6379/0

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ADMIN_CHAT_ID=your_chat_id_here

# UF
UF_API_URL=https://mindicador.cl/api/uf

# Scraping
SCRAPING_INTERVAL_HOURS=4
SCRAPING_DELAY_MIN=3
SCRAPING_DELAY_MAX=8

# Oportunidades
OPPORTUNITY_MIN_SCORE=70
PRICE_DEVIATION_THRESHOLD=-15
MAX_ALERTS_PER_DAY=5
